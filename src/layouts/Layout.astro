---
import '@/styles/global.css'
import '@/styles/typography.css'

import Footer from '@/components/Footer.astro'
import Head from '@/components/Head.astro'
import Header from '@/components/Header.astro'
import { SITE } from '@/consts'
import { cn } from '@/lib/utils'

const defaultFont = 'bezy'
---

<!doctype html>
<html lang={SITE.locale} class={defaultFont === 'bezy' ? 'use-bezy-font' : 'use-geist-font'}>
  <Head>
    <slot name="head" />
  </Head>
  <body>
    <div class="flex h-fit min-h-screen flex-col font-sans">
      <Header />
      <main class="grow">
        <!-- px-[36px]: 1 grid unit (18px = half baseline) -->
        <div class="mx-auto flex grow flex-col px-[36px] w-full">
          <slot />
        </div>
      </main>
      <Footer />
    </div>

    <script is:inline define:vars={{ defaultFont: 'bezy' }}>
      (function() {
        try {
          const font = localStorage.getItem('font') || defaultFont;
          const html = document.documentElement;
          html.classList.remove('use-bezy-font', 'use-geist-font');
          html.classList.add(font === 'bezy' ? 'use-bezy-font' : 'use-geist-font');
          if (!localStorage.getItem('font')) {
            localStorage.setItem('font', defaultFont);
          }
        } catch (e) {
          document.documentElement.classList.add('use-bezy-font');
        }
      })();
    </script>
  </body>
</html>

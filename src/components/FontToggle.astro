---
import { Button } from '@/components/ui/button'
import { Icon } from 'astro-icon/components'

const defaultFont = 'virtua'
---

<Button id="font-toggle" variant="outline" size="icon" title="Toggle font">
  <Icon
    name="lucide:file-type-2"
    class="size-4 scale-100 rotate-0 transition-all use-virtua-font:scale-0 use-virtua-font:-rotate-90"
  />
  <Icon
    name="lucide:file-type"
    class="absolute size-4 scale-0 rotate-90 transition-all use-virtua-font:scale-100 use-virtua-font:rotate-0"
  />
  <span class="sr-only">Toggle font</span>
</Button>

<script is:inline define:vars={{ defaultFont }}>
  function initFontToggle() {
    const btn = document.getElementById('font-toggle');
    if (!btn) return;
    btn.addEventListener('click', () => {
      const html = document.documentElement;
      const isVirtua = html.classList.contains('use-virtua-font');
      html.classList.remove('use-virtua-font', 'use-geist-font');
      html.classList.add(isVirtua ? 'use-geist-font' : 'use-virtua-font');
      localStorage.setItem('font', isVirtua ? 'geist' : 'virtua');
    });
  }

  document.addEventListener('astro:page-load', initFontToggle);
</script>

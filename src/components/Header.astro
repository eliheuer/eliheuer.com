---
import Link from '@/components/Link.astro'
import MobileMenu from '@/components/ui/mobile-menu'
import { NAV_LINKS } from '@/consts'
import { Image } from 'astro:assets'
import logo from '../../public/static/logo-cropped.png'

const path = Astro.url.pathname
let headline: string

if (path === '/') {
  headline = 'Eli Heuer—AI/Design Engineer'
} else if (path.startsWith('/blog')) {
  headline = "Eli Heuer's Blog"
} else if (path.startsWith('/software')) {
  headline = "Eli Heuer's Software Projects"
} else if (path.startsWith('/fonts')) {
  headline = "Eli Heuer's Type Design Projects"
} else if (path.startsWith('/graphics')) {
  headline = "Eli Heuer's Graphic Design Projects"
} else {
  headline = 'Eli Heuer'
}
---

<!-- padding: 1 unit on all sides, margin below for spacing -->
<header class="bg-background/50 sticky top-0 z-10 backdrop-blur-md p-[36px] mb-[36px]">
  <div class="relative flex flex-wrap items-center justify-between">
    <Link href="/" class="shrink-0">
      {headline}
    </Link>

    {/* Logo centered horizontally on the page */}
    <a id="header-logo" href="/" class="absolute left-1/2 -translate-x-1/2 cursor-pointer">
      <Image src={logo} alt="Logo" class="size-6 transition-transform duration-300 hover:scale-125" id="logo-img" />
    </a>

    <div class="flex items-center gap-2">
      <nav class="hidden items-center gap-2 md:flex">
        {
          NAV_LINKS.map((item) => (
            <Link href={item.href} class="capitalize transition-colors">
              {item.label}
            </Link>
          ))
        }
      </nav>
      <MobileMenu client:load transition:persist />
    </div>
  </div>
</header>

<style>
  #header-logo {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    border-radius: 50%;
    transition: box-shadow 0.3s ease;
  }

  #header-logo:hover {
    box-shadow:
      0 0 12px 4px rgba(180, 120, 255, 0.4),
      0 0 24px 8px rgba(100, 200, 255, 0.2);
  }

  #header-logo.pulse {
    animation: logo-pulse 0.6s ease-out;
  }

  @keyframes logo-pulse {
    0% {
      box-shadow:
        0 0 12px 4px rgba(180, 120, 255, 0.6),
        0 0 24px 8px rgba(100, 200, 255, 0.4);
      transform: translateX(-50%) scale(1.3);
    }
    100% {
      box-shadow:
        0 0 0px 0px rgba(180, 120, 255, 0),
        0 0 0px 0px rgba(100, 200, 255, 0);
      transform: translateX(-50%) scale(1);
    }
  }
</style>

<script>
  document.addEventListener('astro:page-load', () => {
    const logo = document.getElementById('header-logo');
    if (!logo) return;

    logo.addEventListener('click', (e) => {
      e.preventDefault();
      logo.classList.remove('pulse');
      void logo.offsetWidth;
      logo.classList.add('pulse');
    });

    logo.addEventListener('animationend', () => {
      logo.classList.remove('pulse');
    });
  });
</script>

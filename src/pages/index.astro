---
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import PostList from '@/components/PostList.astro'
import Layout from '@/layouts/Layout.astro'
import { getAllPosts } from '@/lib/data-utils'

const allPosts = await getAllPosts()
---

<Layout>
  <PageHead slot="head" title="Eli Heuer" />

  <section class="py-8">
    <p>
      I'm an AI and design engineer based in the US. I build
      <a href="https://github.com/eliheuer/runebender-xilem" class="underline">Runebender Xilem</a>,
      a cross-platform open-source font editor written in Rust;
      <a href="https://github.com/eliheuer/img2bez" class="underline">img2bez</a>,
      a raster-to-bezier tracer for type design; Font.Garden, a solo startup
      applying generative AI to vector graphics; and type design nodes for
      <a href="https://github.com/eliheuer/comfyfont" class="underline">ComfyUI</a>.
    </p>
    <p class="text-muted-foreground mt-4 flex flex-wrap gap-x-4 gap-y-1">
      <Link href="https://github.com/eliheuer" class="hover:text-foreground">GitHub</Link>
      <Link href="https://mastodon.social/@eliheuer" class="hover:text-foreground">Mastodon</Link>
      <Link href="https://x.com/eliheuer" class="hover:text-foreground">X/Twitter</Link>
      <Link href="https://www.instagram.com/eli.heuer" class="hover:text-foreground">Instagram</Link>
      <Link href="https://www.youtube.com/@eliheuer" class="hover:text-foreground">YouTube</Link>
      <Link href="https://www.linkedin.com/in/eliheuer" class="hover:text-foreground">LinkedIn</Link>
      <Link href="https://www.tiktok.com/@die_gnu_typographie" class="hover:text-foreground">TikTok</Link>
      <Link href="mailto:elih@protonmail.com" class="hover:text-foreground">Email</Link>
      <Link href="/rss.xml" class="hover:text-foreground">RSS</Link>
    </p>
  </section>

  <section class="pb-8">
    <h2 class="mb-4 font-semibold">Posts</h2>
    <PostList posts={allPosts} />
  </section>
</Layout>

---
import Link from '@/components/Link.astro'
import PageHead from '@/components/PageHead.astro'
import Layout from '@/layouts/Layout.astro'
---

<Layout>
  <PageHead slot="head" title="Index" />

  <section>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-12" style="line-height: 36px;">
      <div class="prose" style="line-height: 36px;">
        <p style="margin: 0;">
        Eli is an AI/design engineer living in the Pacific Northwest.
        </p>
        <p style="margin: 0; margin-top: 36px;">
        He is curently working on a pure Rust cross-platform open-source font editor called <a href="https://github.com/eliheuer/runebender-xilem">Runebender Xilem</a>, a collection of type design nodes for <a href="https://github.com/eliheuer/comfyfont">ComfyUI</a>, and a post-authorship vector graphics AI solo startup called <a href="https://font.garden">Font.Garden</a>.
        </p>
      </div>

      <div class="mt-8 md:mt-0 md:text-right" style="line-height: 36px;">
        <a href="https://github.com/eliheuer">GitHub</a><br />
        <a href="https://x.com/eliheuer">X/Twitter</a><br />
        <a href="https://mastodon.social/@eliheuer">Mastodon</a><br />
        <a href="https://www.linkedin.com/in/eliheuer">LinkedIn</a><br />
        <a href="mailto:elih@protonmail.com">Email</a>
      </div>
    </div>
  </section>
</Layout>
